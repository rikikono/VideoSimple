<?xml version="1.0" encoding="utf-8"?>
<!-- Main Activity Layout - Video browser with toolbar and list -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/rootLayout">

    <!-- Custom Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?android:attr/actionBarSize"
        android:background="@color/toolbarBackground"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/toolbarText"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Sort button -->
        <ImageButton
            android:id="@+id/btnSort"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/sort_by"
            android:src="@drawable/ic_sort"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- Playlist button -->
        <ImageButton
            android:id="@+id/btnPlaylists"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/playlists"
            android:src="@drawable/ic_playlist"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <!-- More options (dark mode, refresh) -->
        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"
            android:src="@drawable/ic_more"
            android:scaleType="centerInside"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Empty state text -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/no_videos_found"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Video list -->
    <ListView
        android:id="@+id/listVideos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@color/colorDivider"
        android:dividerHeight="1dp"
        android:scrollbars="vertical" />

</LinearLayout>
