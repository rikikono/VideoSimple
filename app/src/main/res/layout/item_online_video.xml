<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <ImageView
        android:id="@+id/imgOnlineThumbnail"
        android:layout_width="120dp"
        android:layout_height="68dp"
        android:background="#FFE0E0E0"
        android:contentDescription="@string/online_video_thumbnail"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_video_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvOnlineSourceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#22000000"
            android:paddingStart="8dp"
            android:paddingTop="2dp"
            android:paddingEnd="8dp"
            android:paddingBottom="2dp"
            android:text="@string/sample_label"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOnlineTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOnlineDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>