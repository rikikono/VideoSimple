<?xml version="1.0" encoding="utf-8"?>
<!-- Video Player Activity Layout -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/playerBackground"
    android:keepScreenOn="true">

    <!-- Video Surface -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Gesture overlay - left side (brightness) -->
    <LinearLayout
        android:id="@+id/brightnessOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_start"
        android:layout_marginStart="24dp"
        android:background="@color/gestureOverlayBg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_brightness"
            android:contentDescription="@string/brightness" />

        <ProgressBar
            android:id="@+id/brightnessProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="4dp"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="50"
            android:progressDrawable="@android:drawable/progress_vertical"
            android:rotation="180" />

        <TextView
            android:id="@+id/tvBrightnessValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/gestureOverlayText"
            android:textSize="12sp"
            android:text="50%" />
    </LinearLayout>

    <!-- Gesture overlay - right side (volume) -->
    <LinearLayout
        android:id="@+id/volumeOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_end"
        android:layout_marginEnd="24dp"
        android:background="@color/gestureOverlayBg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_volume"
            android:contentDescription="@string/volume" />

        <ProgressBar
            android:id="@+id/volumeProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="4dp"
            android:layout_height="100dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="50"
            android:rotation="180" />

        <TextView
            android:id="@+id/tvVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/gestureOverlayText"
            android:textSize="12sp"
            android:text="50%" />
    </LinearLayout>

    <!-- Seek overlay (shown during horizontal swipe) -->
    <LinearLayout
        android:id="@+id/seekOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/gestureOverlayBg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSeekPosition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gestureOverlayText"
            android:textSize="24sp"
            android:textStyle="bold"
            android:text="00:00:00" />

        <TextView
            android:id="@+id/tvSeekOffset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/gestureOverlayText"
            android:textSize="14sp"
            android:text="+0 sec" />
    </LinearLayout>

    <!-- Double tap rewind indicator (left) -->
    <FrameLayout
        android:id="@+id/doubleTapLeft"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_vertical|start"
        android:background="@color/gestureOverlayBg"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_rewind"
                android:contentDescription="Rewind" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 sec"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Double tap forward indicator (right) -->
    <FrameLayout
        android:id="@+id/doubleTapRight"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_vertical|end"
        android:background="@color/gestureOverlayBg"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_forward"
                android:contentDescription="Forward" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 sec"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Sleep timer indicator -->
    <TextView
        android:id="@+id/tvSleepTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@color/gestureOverlayBg"
        android:padding="6dp"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Controls Overlay -->
    <RelativeLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#44000000">

        <!-- Top bar with back, title, and options -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_alignParentTop="true"
            android:background="@color/playerControlBg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/ic_back"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/tvVideoTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@color/playerControlText"
                android:textSize="16sp" />

            <!-- Sleep timer button -->
            <ImageButton
                android:id="@+id/btnSleepTimer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/sleep_timer"
                android:src="@drawable/ic_timer"
                android:scaleType="centerInside"
                android:padding="6dp" />

            <!-- Video info button -->
            <ImageButton
                android:id="@+id/btnVideoInfo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/video_info"
                android:src="@drawable/ic_info"
                android:scaleType="centerInside"
                android:padding="6dp" />

        </LinearLayout>

        <!-- Center controls: Previous, Play/Pause, Next -->
        <LinearLayout
            android:id="@+id/centerControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnPrevious"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/previous"
                android:src="@drawable/ic_previous"
                android:scaleType="centerInside"
                android:padding="12dp" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/play"
                android:src="@drawable/ic_play"
                android:scaleType="centerInside"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next"
                android:src="@drawable/ic_next"
                android:scaleType="centerInside"
                android:padding="12dp" />

        </LinearLayout>

        <!-- Bottom bar: SeekBar, time, lock, fullscreen -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@color/playerControlBg"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- SeekBar row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/playerControlText"
                    android:textSize="12sp"
                    android:text="00:00" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:max="100" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/playerControlText"
                    android:textSize="12sp"
                    android:text="00:00" />

            </LinearLayout>

            <!-- Bottom buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <!-- Lock button -->
                <ImageButton
                    android:id="@+id/btnLock"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/lock"
                    android:src="@drawable/ic_lock"
                    android:scaleType="centerInside"
                    android:padding="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Fullscreen button -->
                <ImageButton
                    android:id="@+id/btnFullscreen"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/fullscreen"
                    android:src="@drawable/ic_fullscreen"
                    android:scaleType="centerInside"
                    android:padding="8dp" />

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <!-- Lock overlay (shown when screen is locked) -->
    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnUnlock"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_start|bottom"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            android:background="@color/gestureOverlayBg"
            android:contentDescription="@string/unlock"
            android:src="@drawable/ic_unlock"
            android:scaleType="centerInside"
            android:padding="12dp" />
    </FrameLayout>

</FrameLayout>
